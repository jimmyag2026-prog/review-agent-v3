# review-agent v3 secrets template.
# Copy to ~/.config/review-agent/secrets.env (user install) OR
#         /etc/review-agent/secrets.env (system install) and chmod 600.
# Never commit a filled-in copy.

# === REVIEW LLM (required) ===
DEEPSEEK_API_KEY=

# === LARK (required) — from your Self-Built App ===
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# === MULTIMODAL FALLBACK (optional) ===
# review-agent v3.1+ handles image/audio/PDF/web/Lark-doc URLs out of the box.
# Order it tries for image OCR + voice transcription:
#   1. local tesseract / whisper.cpp (free, no network — install via
#      `review-agent install-multimodal`)
#   2. Gemini API (free tier supports gemini-2.5-flash — set GEMINI_API_KEY)
#   3. OpenAI API (gpt-4o-mini Vision + whisper-1 — set OPENAI_API_KEY)
#   4. else friendly DM "OCR/audio not configured"
# Configure ONE of #2 or #3 if you don't want #1's local install.
GEMINI_API_KEY=
OPENAI_API_KEY=
# override default Gemini model (default: gemini-2.5-flash, free-tier OK).
# To use the paid `gemini-3-pro-preview`, set this AND enable billing first.
# REVIEW_AGENT_GEMINI_MODEL=

# === LLM TUNABLES (optional, set via `review-agent set-model`) ===
# REVIEW_AGENT_MODEL=
# REVIEW_AGENT_FAST_MODEL=
# REVIEW_AGENT_AUTO_REGISTER=true
