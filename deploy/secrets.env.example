# review-agent v3 secrets template.
# Copy to ~/.config/review-agent/secrets.env (user install) OR
#         /etc/review-agent/secrets.env (system install) and chmod 600.
# Never commit a filled-in copy.

# === REVIEW LLM (required) ===
DEEPSEEK_API_KEY=

# === LARK (required) — from your Self-Built App ===
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# === MULTIMODAL FALLBACK (optional) ===
# review-agent v3.1+ handles image/audio/PDF/web/Lark-doc URLs out of the box.
# For best quality + zero local install, add an OpenAI key — used as the
# fallback for image OCR (when tesseract isn't installed) and audio
# transcription (when whisper.cpp isn't installed).
# Skip this if you've run `bash deploy/install-multimodal.sh` and don't need
# the API fallback.
OPENAI_API_KEY=

# === LLM TUNABLES (optional, set via `review-agent set-model`) ===
# REVIEW_AGENT_MODEL=
# REVIEW_AGENT_FAST_MODEL=
# REVIEW_AGENT_AUTO_REGISTER=true
